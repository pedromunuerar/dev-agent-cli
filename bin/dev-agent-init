#!/usr/bin/env python3
import os
import json



def main():
    print("🤖 [Configurando Agente] Escaneando proyecto...")
    tech = input("¿Tecnologías y lenguajes?: ")
    rules = input("¿Reglas de estilo o diseño? (opcional): ")
        
    estructura = ''

    prompt_base = (
        "Actúa como un agente de desarrollo por línea de comandos.\n"
        "Analiza la estructura del proyecto y la tarea solicitada.\n\n"
        "REGLAS DE DECISIÓN:\n"
        "1. Si necesitas ver el contenido de algún archivo de la estructura para cumplir la tarea con precisión, "
        "o si tienes dudas sobre la lógica del usuario, DETENTE inmediatamente. Pide los archivos o directorios "
        "que necesites indicando textualmente qué comando debe ejecutar el usuario, por ejemplo: "
        "'dev-agent-context ruta/archivo.ext' o 'dev-agent-context ruta/directorio1/ ruta/directorio2/'. "
        "También puedes formular preguntas aclaratorias breves.\n"
        "2. Si tienes toda la información necesaria y no hay dudas, genera ÚNICAMENTE un bloque de código Bash ejecutable. "
        "No hables, no expliques, no saludes. Solo código Bash.\n\n"
        "REGLAS DE SCRIPT BASH:\n"
        "- Para crear o reemplazar archivos usa siempre: cat << 'DEVFILEEOF' > ruta/archivo.ext\n"
        "- Asegúrate de usar 'mkdir -p' si creas carpetas nuevas antes de escribir los archivos.")
    
    prompt_base = (
        "Actúa como un agente de desarrollo por línea de comandos.\n"
        "Analiza la estructura del proyecto y la tarea solicitada.\n\n"
        "REGLAS DE DECISIÓN:\n"
        "1. Si necesitas ver el contenido de algún archivo de la estructura para cumplir la tarea con precisión, o si tienes dudas sobre la lógica del usuario, DETENTE inmediatamente. Pide los archivos o directorios que necesites indicando textualmente qué comando debe ejecutar el usuario, por ejemplo: 'dev-agent-context ruta/archivo.ext' (pide los archivos uno a uno), o 'dev-agent-context ruta/directorio1/ ruta/directorio2/'. También puedes formular preguntas aclaratorias breves.\n"
        "2. Si tienes toda la información necesaria y no hay dudas, genera dos tipos de salida, **sin explicaciones ni texto adicional**:\n"
        "a) Un **script Bash** que:\n"
        "- Crea toda la estructura de directorios que sea necesario añadir (con `mkdir -p`).\n"
        "- Crea todos los nuevos archivos necesarios (con `touch`).\n"
        "- Abre cada uno de esos archivos en VS Code usando `code` (si el usuario prefiere otro editor, se usará el comando indicado, por defecto `code`).\n"
        "- No escriba contenido dentro de los archivos, solo los deje abiertos.\n"
        "b) A continuación, por cada archivo, un **bloque de código independiente** con el contenido completo, encabezado ÚNICAMENTE por un comentario con la ruta relativa del archivo\n"

    )

    context = {
        "prompt_system": prompt_base,
        "tecnologia": tech,
        "reglas_estilo": rules,
        "estructura_directorios": estructura
    }
    
    with open(".agent-context.json", "w", encoding="utf-8") as f:
        json.dump(context, f, indent=4, ensure_ascii=False)
    
    print("✅ Archivo .agent-context.json actualizado con el nuevo protocolo de comunicación.")

if __name__ == "__main__":
    main()
